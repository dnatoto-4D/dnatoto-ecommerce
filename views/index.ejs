<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <title><%= brandName %> | Destinasi Produk Teknologi & Gaya Hidup Premium</title>
    <meta name="description" content="Dnatoto adalah platform e-commerce eksklusif yang menyediakan koleksi hardware, aksesoris tech, dan kebutuhan gaya hidup modern dengan garansi resmi dan kualitas terbaik.">
    <meta name="keywords" content="Dnatoto, e-commerce gadget, aksesoris premium, produk teknologi, gaya hidup modern, belanja online aman">
    <meta name="author" content="<%= brandName %>">
    <meta name="robots" content="index, follow">

    <link rel="canonical" href="https://dnatoto4d.vercel.app/" />

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://dnatoto4d.vercel.app/">
    <meta property="og:title" content="<%= brandName %> | Excellence Redefined">
    <meta property="og:description" content="Dapatkan koleksi perangkat teknologi terbaru dengan standar global hanya di <%= brandName %>.">
    <meta property="og:image" content="https://images.unsplash.com/photo-1441986300917-64674bd600d8"> <meta property="og:site_name" content="<%= brandName %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= brandName %> | Excellence Redefined">
    <meta name="twitter:description" content="Platform e-commerce premium untuk gaya hidup digital Anda.">
    <meta name="twitter:image" content="https://images.unsplash.com/photo-1441986300917-64674bd600d8">

    <link rel="icon" type="image/png" href="/favicon.png"> <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        #mobileMenu {
            background-color: #0f172a; 
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateX(100%);
            opacity: 0;
            pointer-events: none;
        }
        
        .menu-active {
            transform: translateX(0) !important;
            opacity: 1 !important;
            pointer-events: auto !important;
        }

        @media (max-width: 1023px) {
            body { padding-bottom: 90px; }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <nav class="bg-white sticky top-0 z-[100] border-b border-gray-100 h-16 md:h-20 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 md:px-6 h-full flex justify-between items-center">
            
            <div class="flex items-center w-1/3">
                <a href="/" class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tighter uppercase italic">
                    <%= brandName %><span class="text-indigo-600">.</span>
                </a>
            </div>

            <div class="hidden lg:flex flex-1 justify-center space-x-10 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-500">
                <a href="#produk" class="hover:text-indigo-600 transition">Koleksi</a>
                <a href="#kategori" class="hover:text-indigo-600 transition">Keunggulan</a>
                <a href="#testimoni" class="hover:text-indigo-600 transition">Testimoni</a>
            </div>

            <div class="flex items-center justify-end space-x-4 w-1/3">
                <div class="hidden lg:flex items-center space-x-6">
                    <a href="<%= loginUrl %>" target="_blank" class="text-[11px] font-bold hover:text-indigo-600 transition">LOGIN</a>
                    <a href="<%= registerUrl %>" target="_blank" class="bg-indigo-600 text-white px-6 py-2.5 rounded-full text-[10px] font-black uppercase shadow-lg shadow-indigo-100 hover:bg-slate-900 transition">Daftar</a>
                </div>
                
                <button onclick="toggleMenu()" class="lg:hidden relative z-[110] text-2xl p-2 text-slate-900 focus:outline-none">
                    <i id="menuIcon" class="fa-solid fa-bars-staggered transition-all duration-300"></i>
                </button>
            </div>
        </div>

        <div id="mobileMenu" class="fixed inset-0 z-[105] flex flex-col p-8 lg:hidden">
            <div class="mt-12 flex flex-col space-y-8">
                <p class="text-[10px] font-bold text-indigo-400 uppercase tracking-[0.3em]">Menu Utama</p>
                <a href="#produk" onclick="toggleMenu()" class="text-4xl font-black text-white italic tracking-tighter">PRODUK</a>
                <a href="#kategori" onclick="toggleMenu()" class="text-4xl font-black text-white italic tracking-tighter">KEUNGGULAN</a>
                <a href="#testimoni" onclick="toggleMenu()" class="text-4xl font-black text-white italic tracking-tighter">TESTIMONI</a>
            </div>

            <div class="mt-auto space-y-4 mb-10">
                <a href="<%= loginUrl %>" target="_blank" class="flex justify-center items-center w-full bg-slate-800 text-white h-14 rounded-2xl font-bold text-sm uppercase tracking-widest border border-slate-700">
                    Login ke Akun
                </a>
                <a href="<%= registerUrl %>" target="_blank" class="flex justify-center items-center w-full bg-indigo-600 text-white h-14 rounded-2xl font-black text-sm uppercase tracking-widest shadow-xl shadow-indigo-500/20">
                    Daftar Sekarang
                </a>
            </div>
        </div>
    </nav>

    <main>
        <header class="relative h-[60vh] md:h-[80vh] bg-slate-900 flex items-center overflow-hidden">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1441986300917-64674bd600d8')] bg-cover bg-center opacity-40"></div>
            <div class="relative max-w-7xl mx-auto px-6 text-white">
                <h1 class="text-5xl md:text-8xl font-black italic tracking-tighter uppercase leading-none">The Future <br> of Tech.</h1>
                <p class="mt-6 text-gray-300 max-w-lg text-sm md:text-lg italic">Dnatoto: Menyediakan perlengkapan teknologi dan gaya hidup premium dengan standar internasional.</p>
                <a href="#produk" class="inline-block mt-8 bg-indigo-600 text-white px-10 py-4 rounded-full font-bold uppercase text-xs tracking-[0.2em] shadow-xl hover:bg-white hover:text-slate-900 transition duration-300">Belanja Sekarang</a>
            </div>
        </header>

        <section id="kategori" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-10">
                <div class="text-center md:text-left">
                    <i class="fa-solid fa-bolt text-indigo-600 text-3xl mb-4"></i>
                    <h4 class="font-bold text-sm uppercase tracking-wider">Fast Delivery</h4>
                    <p class="text-xs text-gray-500 mt-2">Pengiriman ekspres dalam 24 jam ke seluruh wilayah.</p>
                </div>
                <div class="text-center md:text-left">
                    <i class="fa-solid fa-shield text-indigo-600 text-3xl mb-4"></i>
                    <h4 class="font-bold text-sm uppercase tracking-wider">Safe Payment</h4>
                    <p class="text-xs text-gray-500 mt-2">Sistem pembayaran terenkripsi dan 100% aman.</p>
                </div>
                <div class="text-center md:text-left">
                    <i class="fa-solid fa-award text-indigo-600 text-3xl mb-4"></i>
                    <h4 class="font-bold text-sm uppercase tracking-wider">Official DNA</h4>
                    <p class="text-xs text-gray-500 mt-2">Produk original dengan sertifikat garansi resmi.</p>
                </div>
                <div class="text-center md:text-left">
                    <i class="fa-solid fa-arrows-rotate text-indigo-600 text-3xl mb-4"></i>
                    <h4 class="font-bold text-sm uppercase tracking-wider">30-Day Return</h4>
                    <p class="text-xs text-gray-500 mt-2">Jaminan uang kembali jika produk tidak sesuai ekspektasi.</p>
                </div>
            </div>
        </section>

        <section id="produk" class="py-20 max-w-7xl mx-auto px-6">
            <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-12">New Collection</h2>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-10">
                <% products.forEach(p => { %>
                <div class="group bg-white p-2 rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl transition duration-500">
                    <div class="aspect-[4/5] overflow-hidden rounded-xl bg-gray-50 mb-4 relative">
                        <span class="absolute top-2 left-2 bg-indigo-600 text-white text-[8px] font-bold px-2 py-1 rounded z-10 uppercase"><%= p.tag %></span>
                        <img src="<%= p.img %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    </div>
                    <div class="px-2 pb-2">
                        <h3 class="font-bold text-[10px] md:text-sm uppercase tracking-tight"><%= p.name %></h3>
                        <p class="text-indigo-600 font-bold text-xs md:text-sm mt-1">IDR <%= p.price %></p>
                        <button class="w-full mt-4 bg-slate-900 text-white py-3 rounded-lg text-[9px] font-bold uppercase tracking-widest hover:bg-indigo-600 transition duration-300">Beli Sekarang</button>
                    </div>
                </div>
                <% }) %>
            </div>
        </section>
    </main>

    <div class="fixed lg:hidden bottom-4 left-4 right-4 z-[90] flex gap-3">
        <a href="<%= loginUrl %>" target="_blank" class="flex-1 bg-white/95 backdrop-blur-md border border-gray-200 text-slate-900 h-14 rounded-2xl flex items-center justify-center font-bold text-xs uppercase shadow-xl tracking-widest">
            Login
        </a>
        <a href="<%= registerUrl %>" target="_blank" class="flex-[2.5] bg-indigo-600 text-white h-14 rounded-2xl flex items-center justify-center font-black text-xs uppercase shadow-2xl shadow-indigo-300/50 tracking-[0.1em]">
            Daftar Sekarang
        </a>
    </div>

    <script>
        function toggleMenu() {
            const menu = document.getElementById('mobileMenu');
            const icon = document.getElementById('menuIcon');
            const isOpen = menu.classList.contains('menu-active');

            if (!isOpen) {
                // Open
                menu.classList.add('menu-active');
                icon.classList.remove('fa-bars-staggered');
                icon.classList.add('fa-xmark', 'text-white');
                document.body.style.overflow = 'hidden';
            } else {
                // Close
                menu.classList.remove('menu-active');
                icon.classList.remove('fa-xmark', 'text-white');
                icon.classList.add('fa-bars-staggered');
                document.body.style.overflow = '';
            }
        }
    </script>
</body>
</html>